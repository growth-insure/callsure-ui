# Public Supabase project URL used by the frontend and API routes.
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase anon key used for client-side auth and REST requests.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Browser tab title for this client deployment. Example: CallSure
NEXT_PUBLIC_TAB_INFO_TITLE=

# Browser tab/meta description for this client deployment.
NEXT_PUBLIC_TAB_INFO_DESCRIPTION=

# Optional logo URL shown on login and pending-approval pages.
NEXT_PUBLIC_LOGIN_LOGO=

# Audio source shown in the top header. Supported values: lightspeedvoice, ringcentral.
# Leave blank to default to lightspeedvoice.
NEXT_PUBLIC_AUDIO_SOURCE_CLIENT=

# SendGrid API key used for transactional emails like password reset and welcome emails.
NEXT_PUBLIC_SENDGRID_API_KEY=

# Verified sender email address used by SendGrid.
NEXT_PUBLIC_SENDGRID_FROM_EMAIL=

# Supabase service role key used by server-side routes only.
NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=

# Base app URL used when generating links in emails.
NEXT_PUBLIC_APP_URL=

# Redirect URL used after password reset is completed.
NEXT_PUBLIC_PASSWORD_RESET_REDIRECT=
